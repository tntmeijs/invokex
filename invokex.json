{
    "messagebroker": {
        "host": "localhost:5672",
        "username": "invokex",
        "password": "admin",
        "queues": {
            "unpack_archive": {
                "name": "user.application.archive.unpack"
            },
            "create_filesystem": {
                "name": "user.application.archive.filesystem"
            }
        },
        "exchanges": {
            "application": {
                "name": "invokex.user.application",
                "bindings": [
                    {
                        "id": "unpack_archive",
                        "key": "user.application.archive.unpack"
                    },
                    {
                        "id": "create_filesystem",
                        "key": "user.application.archive.filesystem"
                    }
                ]
            }
        }
    },
    "application": {
        "upload": {
            "directory": ".invokex/upload",
            "output": ".invokex/output"
        }
    },
    "firecracker": {
        "instance": {
            "path": ".invokex/firecracker/firecracker"
        },
        "kernel": {
            "path": ".invokex/runtime/kernel.bin"
        },
        "rootfs": {
            "path": ".invokex/runtime/rootfs_golang_x86_64.ext4"
        },
        "directories": {
            "firecrackerlogs": ".invokex/firecrackerlogs",
            "vmconfigs": ".invokex/vmconfigs",
            "apisockets": ".invokex/apisockets",
            "vmlogs": ".invokex/vmlogs"
        }
    }
}